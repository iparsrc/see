# -*- mode: ruby -*-
# vi: set ft=ruby :

Vagrant.configure("2") do |config|

  # Shared base box
  config.vm.box = "bento/ubuntu-24.04"

  # Shared provisioning
  config.vm.provision "shell", inline: <<-SHELL
    apt-get update
  SHELL

  ## ===============================
  ## Integration VM
  ## ===============================
  config.vm.define "integration-server" do |integration-server|
    integration-server.vm.hostname = "integration-server"

    integration-server.vm.network "forwarded_port", guest: 80, host: 8080
    integration-server.vm.network "private_network", ip: "192.168.56.9"

    integration-server.vm.synced_folder "./data-integration", "/vagrant_data"

    integration-server.vm.provider "virtualbox" do |vb|
      vb.memory = 3 * 1024
      vb.cpus = 3
    end

    integration-server.vm.provision "ansible" do |ansible|
      ansible.playbook = "playbooks/integration.yml"
    end
  end

  ## ===============================
  ## Deployment VM
  ## ===============================
  config.vm.define "deployment-server" do |deployment-server|
    deployment-server.vm.hostname = "deployment-server"

    deployment-server.vm.network "forwarded_port", guest: 80, host: 8081
    deployment-server.vm.network "private_network", ip: "192.168.56.10"

    deployment-server.vm.synced_folder "./data-deployment", "/vagrant_data"

    deployment-server.vm.provider "virtualbox" do |vb|
      vb.memory = 3 * 1024
      vb.cpus = 3
    end

    deployment-server.vm.provision "ansible" do |ansible|
      ansible.playbook = "playbooks/deployment.yml"
    end
  end
end
